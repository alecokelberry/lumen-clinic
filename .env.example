# ─── Clerk (https://dashboard.clerk.com) ──────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Supabase (https://supabase.com/dashboard) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Root domain for multi-tenant subdomain routing (e.g. clinic.lumenclinic.health)
NEXT_PUBLIC_ROOT_DOMAIN=lumenclinic.health

# ─── Resend (https://resend.com) ──────────────────────────────────────────────
# Used for booking confirmation emails. App works without this (logs to console).
RESEND_API_KEY=

# ─── Stripe (https://dashboard.stripe.com) ────────────────────────────────────
# Required for bill pay (Phase 2 — not yet active)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
